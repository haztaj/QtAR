# Release-signing config for the demo app (consumed by sdk/android/demo/build.gradle.kts).
#
# Copy this file to `keystore.properties` (SAME directory) and fill in real values. The real
# file AND the keystore are gitignored — never commit either, and back up the keystore + passwords
# somewhere safe: losing the key means you can no longer ship updates that overwrite an installed
# build (and, for self-managed Play signing, can't update the Play listing at all).
#
# 1. Generate a keystore (run once; pick your own strong passwords when prompted):
#
#      keytool -genkeypair -v \
#        -keystore quranrecite-release.jks \
#        -alias quranrecite \
#        -keyalg RSA -keysize 2048 -validity 10000
#
#    Put quranrecite-release.jks somewhere outside the repo (or in sdk/android — it's gitignored),
#    then point storeFile at it below (absolute path, or relative to sdk/android).
#
# 2. Fill in the four values below to match what you chose.
#
# 3. Build a signed release:
#      ./gradlew :demo:assembleRelease   # -> demo/build/outputs/apk/release/demo-release.apk  (sideload beta)
#      ./gradlew :demo:bundleRelease     # -> demo/build/outputs/bundle/release/demo-release.aab (Play upload)
#
# Play App Signing: upload the .aab; Google re-signs with the app key and this keystore becomes your
# UPLOAD key (resettable if lost). Self-managed / sideload: this IS the app key (not resettable).

storeFile=quranrecite-release.jks
storePassword=CHANGE_ME
keyAlias=quranrecite
keyPassword=CHANGE_ME
