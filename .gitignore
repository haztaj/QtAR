# Audio + datasets — NEVER commit (standing rule)
data/raw/
# recorded live-demo sessions (audio + detections)
demo/sessions/
*.parquet
*.mp3
*.wav
*.flac

# Large generated manifests / features
data/manifests/*.jsonl.gz
data/fbank/
*.h5
*.lilcom

# Models / checkpoints / exports
*.pt
*.onnx
exp/
**/checkpoints/

# Python
__pycache__/
*.pyc
.venv/
env/
*.egg-info/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Keep these small text assets tracked (override the broad ignores above)
!data/lang/tokens.txt
!data/lang/ayah_phonemes.json
!data/manifests/ayah_text.json

# Third-party clone (not part of this project)
icefall/

# C++ build artifacts (keep vendored sources like third_party/)
sdk/build/

# Android — Gradle/AGP build outputs + bundled runtime assets (repopulated by bundleAssets)
sdk/android/**/build/
sdk/android/.gradle/
sdk/android/local.properties
sdk/android/**/.cxx/
# Release-signing secrets — NEVER commit (keystore + its passwords). See keystore.properties.example.
sdk/android/keystore.properties
*.jks
*.keystore
sdk/android/quranrecite/src/main/assets/quranrecite/
sdk/android/demo/src/main/assets/quranrecite/
# KFGQPC V2 mushaf assets (fonts + layout/words DBs) — large third-party binaries
sdk/android/demo/src/main/assets/mushaf/
# Page fonts relocated out of the APK (downloaded once at runtime; -PbundleFonts re-adds them)
sdk/android/demo/mushaf-fonts/

# Local Claude settings
.claude/settings.local.json

# Local revert snapshots (models/exports/manifests) — not for git
backups/
